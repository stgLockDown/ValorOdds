# Database (Railway auto-injects DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:port/dbname

# JWT Secret (set this in Railway environment variables)
JWT_SECRET=your-secure-jwt-secret-here

# Port (Railway auto-injects PORT)
PORT=5000

# Node environment
NODE_ENV=production

# ── Stripe (set these in Railway environment variables) ──
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here

# Get this from Stripe Dashboard → Developers → Webhooks
# Webhook endpoint: https://your-domain.railway.app/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Create these in Stripe Dashboard → Products → Pricing
# Premium plan ($29/month): Create a product, add a $29/month price, copy the price ID
STRIPE_PRICE_PREMIUM=price_xxxxxxxxxxxxxxxxx

# VIP plan ($79/month): Create a product, add a $79/month price, copy the price ID
STRIPE_PRICE_VIP=price_xxxxxxxxxxxxxxxxx

# Optional: Override the client URL (Railway auto-detects RAILWAY_PUBLIC_DOMAIN)
# CLIENT_URL=https://your-domain.railway.app