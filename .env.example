# ── Groq API (Required) ────────────────────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Service Security (Optional) ───────────────────────────────────────────
# Set this to protect your API endpoints with a key
# Your platform must send this in the X-API-Key header
# Leave blank for open access (not recommended in production)
SERVICE_API_KEY=your_secret_service_key_here

# ── Server Config (Railway sets PORT automatically) ───────────────────────
PORT=8000